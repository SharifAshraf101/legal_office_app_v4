# Cloudflare backend config for the app (copy to .env.local and fill in).
# .env.local is gitignored. NEXT_PUBLIC_* values are inlined into the browser
# bundle at build time — the APP_TOKEN here is therefore not truly secret (same
# exposure as the old Supabase anon key); it gates casual access alongside the
# Worker's CORS origin lock.

# The deployed Worker's URL, e.g. https://legal-office-api.<your-subdomain>.workers.dev
NEXT_PUBLIC_WORKER_URL=

# Must match the APP_TOKEN secret you set on the Worker:
#   cd worker && wrangler secret put APP_TOKEN
NEXT_PUBLIC_APP_TOKEN=

